FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source

FROM debian:13.4 AS base

ENV PYTHONUNBUFFERED=1

ARG TARGETARCH
ARG DEBIAN_MIRROR=http://deb.debian.org/debian
ARG DEBIAN_SECURITY_MIRROR=http://deb.debian.org/debian-security

# Runtime image for Go-backend integration:
# - keeps Hermes core + runtime_manager
# - keeps network/debug/system tools that Hermes may call
# - drops dashboard/TUI/Playwright/Node build chain entirely
RUN set -eu; \
    find /etc/apt -type f \( -name '*.list' -o -name '*.sources' \) \
        -exec sed -i \
            -e "s|http://deb.debian.org/debian-security|${DEBIAN_SECURITY_MIRROR}|g" \
            -e "s|http://deb.debian.org/debian|${DEBIAN_MIRROR}|g" {} +; \
    apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 update; \
    DEBIAN_FRONTEND=noninteractive apt-get \
        -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 \
        install -y --no-install-recommends \
        bind9-dnsutils ca-certificates conntrack curl ethtool git \
        inetutils-telnet iperf3 iproute2 iptables iputils-ping jq less \
        lsof mtr-tiny net-tools netcat-openbsd nmap openssh-client openssl \
        procps python3 ripgrep socat tcpdump traceroute whois xz-utils; \
    rm -rf /var/lib/apt/lists/*

ARG KUBECTL_VERSION=v1.36.1
RUN set -eu; \
    case "${TARGETARCH:-amd64}" in \
        amd64|arm64) kubectl_arch="${TARGETARCH:-amd64}" ;; \
        *) echo "Unsupported TARGETARCH=${TARGETARCH} for kubectl" >&2; exit 1 ;; \
    esac; \
    curl -fsSL --retry 3 -o /usr/local/bin/kubectl \
        "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${kubectl_arch}/kubectl"; \
    curl -fsSL --retry 3 -o /tmp/kubectl.sha256 \
        "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${kubectl_arch}/kubectl.sha256"; \
    printf '%s  %s\n' "$(cat /tmp/kubectl.sha256)" /usr/local/bin/kubectl | sha256sum -c -; \
    chmod +x /usr/local/bin/kubectl; \
    rm /tmp/kubectl.sha256; \
    kubectl version --client=true

COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/

RUN useradd -u 10000 -m -d /opt/data hermes

WORKDIR /opt/hermes

FROM base AS builder

# Build-only deps: keep them out of the final image.
RUN set -eu; \
    apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 update; \
    DEBIAN_FRONTEND=noninteractive apt-get \
        -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 \
        install -y --no-install-recommends \
        build-essential gcc libffi-dev python3-dev; \
    rm -rf /var/lib/apt/lists/*

# Only install Python deps needed by runtime_manager. This avoids the huge
# [all] extra and all web/TUI/dashboard related JS/browser layers.
COPY pyproject.toml uv.lock ./
RUN touch ./README.md
RUN uv sync --frozen --no-install-project --extra web

# Copy only the source trees needed by Hermes runtime_manager and the agent core.
COPY --chown=hermes:hermes agent/ /opt/hermes/agent/
COPY --chown=hermes:hermes tools/ /opt/hermes/tools/
COPY --chown=hermes:hermes hermes_cli/ /opt/hermes/hermes_cli/
COPY --chown=hermes:hermes gateway/ /opt/hermes/gateway/
COPY --chown=hermes:hermes cron/ /opt/hermes/cron/
COPY --chown=hermes:hermes plugins/ /opt/hermes/plugins/
COPY --chown=hermes:hermes providers/ /opt/hermes/providers/
COPY --chown=hermes:hermes runtime_manager/ /opt/hermes/runtime_manager/
COPY --chown=hermes:hermes skills/ /opt/hermes/skills/
COPY --chown=hermes:hermes acp_adapter/ /opt/hermes/acp_adapter/

COPY --chown=hermes:hermes run_agent.py /opt/hermes/
COPY --chown=hermes:hermes model_tools.py /opt/hermes/
COPY --chown=hermes:hermes toolsets.py /opt/hermes/
COPY --chown=hermes:hermes batch_runner.py /opt/hermes/
COPY --chown=hermes:hermes trajectory_compressor.py /opt/hermes/
COPY --chown=hermes:hermes toolset_distributions.py /opt/hermes/
COPY --chown=hermes:hermes cli.py /opt/hermes/
COPY --chown=hermes:hermes hermes_bootstrap.py /opt/hermes/
COPY --chown=hermes:hermes hermes_constants.py /opt/hermes/
COPY --chown=hermes:hermes hermes_state.py /opt/hermes/
COPY --chown=hermes:hermes hermes_time.py /opt/hermes/
COPY --chown=hermes:hermes hermes_logging.py /opt/hermes/
COPY --chown=hermes:hermes utils.py /opt/hermes/

RUN uv pip install --no-cache-dir --no-deps -e "."

FROM base AS runtime

WORKDIR /opt/hermes

COPY --from=builder --chown=hermes:hermes /opt/hermes /opt/hermes

ENV HERMES_HOME=/opt/data
ENV RUNTIME_MANAGER_USERS_ROOT=/opt/data/users
ENV RUNTIME_MANAGER_PORT=8765
ENV RUNTIME_MANAGER_HOST=0.0.0.0
ENV PATH="/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH}"

# The venv stays writable so Hermes lazy dependency installs can still work
# for optional backends/tools the first time they are used.
RUN mkdir -p /opt/data/users && \
    chmod -R a+rX /opt/hermes && \
    chown -R hermes:hermes /opt/data

VOLUME ["/opt/data"]
EXPOSE 8765

USER hermes

# Set RUNTIME_MANAGER_API_KEY in your Deployment/Compose config.
ENTRYPOINT ["hermes-runtime-manager"]
